{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://allwayzmags.com"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://allwayzmags.com https://allwayzmags.myshopify.com"
        }
      ]
    }
  ]
}
